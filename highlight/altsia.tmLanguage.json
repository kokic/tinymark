{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Altsia",
  "scopeName": "source.altsia",
  "fileTypes": [
    "altsia"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#fenced-block"
    },
    {
      "include": "#list-sugar"
    },
    {
      "include": "#special-form"
    },
    {
      "include": "#attribute-list"
    },
    {
      "include": "#element-or-reference"
    },
    {
      "include": "#inline"
    },
    {
      "include": "#parens"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-semicolon.altsia",
          "match": ";;.*$"
        }
      ]
    },
    "fenced-block": {
      "patterns": [
        {
          "name": "markup.raw.block.altsia",
          "begin": "(?m)^(```.*)$",
          "beginCaptures": {
            "1": {
              "name": "punctuation.definition.raw.begin.altsia"
            }
          },
          "end": "(?m)^\\1$",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.raw.end.altsia"
            }
          }
        }
      ]
    },
    "list-sugar": {
      "patterns": [
        {
          "name": "markup.list.unnumbered.altsia",
          "match": "^(\\s*)(-)(?=\\s|$)",
          "captures": {
            "2": {
              "name": "punctuation.definition.list.begin.altsia"
            }
          }
        },
        {
          "name": "markup.list.numbered.altsia",
          "match": "^(\\s*)(\\+)(?=\\s|$)",
          "captures": {
            "2": {
              "name": "punctuation.definition.list.begin.altsia"
            }
          }
        }
      ]
    },
    "special-form": {
      "patterns": [
        {
          "name": "meta.expression.special.altsia",
          "begin": "(\\()(\\s*)(def|meta|html\\.head|when|unless)(?=\\s|\\))",
          "beginCaptures": {
            "1": {
              "name": "punctuation.section.expression.begin.altsia"
            },
            "3": {
              "name": "keyword.control.altsia"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.expression.end.altsia"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#fenced-block"
            },
            {
              "include": "#special-form"
            },
            {
              "include": "#attribute-list"
            },
            {
              "include": "#element-or-reference"
            },
            {
              "include": "#inline"
            },
            {
              "include": "#symbols"
            }
          ]
        }
      ]
    },
    "attribute-list": {
      "patterns": [
        {
          "name": "meta.attributes.altsia",
          "begin": "(\\()(\\s*)(:)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.section.attributes.begin.altsia"
            },
            "3": {
              "name": "punctuation.definition.attribute.altsia"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.attributes.end.altsia"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "match": "(:)([^\\s()\"`]+)",
              "captures": {
                "1": {
                  "name": "punctuation.definition.attribute.altsia"
                },
                "2": {
                  "name": "entity.other.attribute-name.altsia"
                }
              }
            },
            {
              "include": "#values"
            },
            {
              "include": "#attribute-reference"
            }
          ]
        }
      ]
    },
    "element-or-reference": {
      "patterns": [
        {
          "name": "meta.expression.altsia",
          "begin": "(\\()(\\s*)(?!:)([^\\s()\"`]+)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.section.expression.begin.altsia"
            },
            "3": {
              "name": "entity.name.tag.altsia"
            }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": {
              "name": "punctuation.section.expression.end.altsia"
            }
          },
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#fenced-block"
            },
            {
              "include": "#special-form"
            },
            {
              "include": "#attribute-list"
            },
            {
              "include": "#element-or-reference"
            },
            {
              "include": "#inline"
            }
          ]
        }
      ]
    },
    "attribute-reference": {
      "patterns": [
        {
          "name": "variable.other.reference.altsia",
          "match": "(\\()(\\s*)([^\\s()\"`]+)(\\s*)(\\))",
          "captures": {
            "1": {
              "name": "punctuation.section.reference.begin.altsia"
            },
            "3": {
              "name": "variable.other.reference.name.altsia"
            },
            "5": {
              "name": "punctuation.section.reference.end.altsia"
            }
          }
        }
      ]
    },
    "inline": {
      "patterns": [
        {
          "include": "#strings"
        },
        {
          "include": "#emphasis"
        },
        {
          "include": "#escapes"
        }
      ]
    },
    "values": {
      "patterns": [
        {
          "include": "#strings"
        },
        {
          "name": "constant.language.boolean.altsia",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "include": "#escapes"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.raw.altsia",
          "begin": "`",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.altsia"
            }
          },
          "end": "`",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.altsia"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.altsia",
              "match": "\\\\`"
            }
          ]
        },
        {
          "name": "string.quoted.double.altsia",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.altsia"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.altsia"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.altsia",
              "match": "\\\\."
            },
            {
              "name": "variable.other.interpolation.altsia",
              "match": "(\\()([^\\s()\"`]+)(\\))",
              "captures": {
                "1": {
                  "name": "punctuation.section.interpolation.begin.altsia"
                },
                "2": {
                  "name": "variable.other.interpolation.name.altsia"
                },
                "3": {
                  "name": "punctuation.section.interpolation.end.altsia"
                }
              }
            }
          ]
        }
      ]
    },
    "emphasis": {
      "patterns": [
        {
          "name": "markup.bold.altsia",
          "begin": "\\*\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.bold.begin.altsia"
            }
          },
          "end": "\\*\\*",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.bold.end.altsia"
            }
          }
        },
        {
          "name": "markup.italic.altsia",
          "begin": "\\*",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.italic.begin.altsia"
            }
          },
          "end": "\\*",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.italic.end.altsia"
            }
          }
        }
      ]
    },
    "escapes": {
      "patterns": [
        {
          "name": "constant.character.escape.altsia",
          "match": "\\\\[()\\\\`*\\-+]"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "constant.language.boolean.altsia",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "variable.other.symbol.altsia",
          "match": "[^\\s()\"`]+"
        }
      ]
    },
    "parens": {
      "patterns": [
        {
          "name": "punctuation.section.expression.begin.altsia",
          "match": "\\("
        },
        {
          "name": "punctuation.section.expression.end.altsia",
          "match": "\\)"
        }
      ]
    }
  }
}
