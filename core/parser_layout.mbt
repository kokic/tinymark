///|
fn skip_line_comment(cursor : Cursor) -> Cursor {
  let mut index = cursor.index
  while index < cursor.length() && cursor.char_at(index) != '\n' {
    index += 1
  }
  cursor.at(index)
}

///|
fn skip_attach_space(cursor : Cursor) -> (Cursor, Bool) {
  let mut index = cursor.index
  let mut newline_count = 0
  while index < cursor.length() {
    let ch = cursor.char_at(index)
    if ch == ' ' || ch == '\t' || ch == '\r' {
      index += 1
      continue
    }
    if ch == '\n' {
      newline_count += 1
      if newline_count >= 2 {
        return (cursor.at(index), true)
      }
      index += 1
      continue
    }
    break
  }
  (cursor.at(index), false)
}

///|
fn skip_content_layout(
  cursor : Cursor,
  close : Char?,
  can_skip_spaces : Bool,
) -> Cursor {
  let mut current = cursor
  let mut skip_spaces = can_skip_spaces
  let mut keep_going = true
  while keep_going {
    keep_going = false
    let spaced = current.skip_spaces()
    match close {
      Some(ch) if spaced.peek() == Some(ch) => return spaced
      _ => ()
    }
    if spaced.is_end() {
      return spaced
    }
    if spaced.starts_with(";;") {
      current = skip_line_comment(spaced)
      skip_spaces = true
      keep_going = true
    } else if spaced.peek() == Some('\n') {
      current = spaced.advance(1)
      skip_spaces = true
      keep_going = true
    } else if skip_spaces {
      current = spaced
    }
  }
  current
}
